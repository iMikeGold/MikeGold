{
  "name": "main-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:cloudflare": "opennextjs-cloudflare build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "hats:audit": "node scripts/audit-hat-system.mjs",
    "hats:audit-attributes": "node scripts/audit-hat-attributes.mjs",
    "hats:ledger": "node scripts/generate-hat-capability-ledger.mjs",
    "work:ledger": "node scripts/generate-work-contribution-ledger.mjs",
    "semantics:ledgers": "node scripts/generate-semantic-concept-ledgers.mjs",
    "hats:assign-uuids": "node scripts/assign-hat-uuids.mjs",
    "records:generate": "node scripts/generate-record-indexes.mjs",
    "records:seed-section-ten": "node scripts/seed-section-ten-projects.mjs",
    "records:ingest-assets": "node scripts/ingest-project-assets.mjs",
    "records:validate": "node scripts/validate-records.mjs",
    "services:validate-knowledge": "node scripts/validate-service-knowledge.mjs",
    "services:test-validator": "node scripts/test-service-knowledge-validator.mjs",
    "services:test": "node scripts/test-semantic-vertical-slice.mjs",
    "services:typecheck": "tsc --noEmit",
    "services:test-queries": "node scripts/run-service-engine-query-matrix.mjs",
    "services:test-determinism": "node scripts/test-service-engine-determinism.mjs",
    "services:trace-admission": "node scripts/run-service-engine-admission-trace.mjs",
    "services:validate-retrieval-boundaries": "node scripts/validate-retrieval-boundaries.mjs",
    "services:validate-runtime": "node scripts/validate-service-runtime.mjs",
    "records:check": "npm run records:generate && npm run records:validate && npm run services:validate-knowledge",
    "predev": "npm run records:check",
    "prebuild": "npm run services:validate-runtime && npm run records:check"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.114.0"
  }
}
